{
  "name": "@jot/app",
  "version": "2.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "macos": "expo run:macos",
    "expo": "expo",
    "prebuild": "expo prebuild",
    "create:migration": "tsx scripts/createMigration.ts",
    "test:migrations": "tsx scripts/testMigrations.ts",
    "test:migrations:up": "pnpm test:migrations up --seeds",
    "test:migrations:down": "pnpm test:migrations down",
    "test:migrations:reset": "pnpm test:migrations reset",
    "test:migrations:status": "pnpm test:migrations status",
    "download:models": "tsx scripts/downloadModels.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --no-watchman",
    "test:run": "jest --no-watchman",
    "test:ts": "jest --no-watchman",
    "test:swift": "cd packages/widget-utils && swift test",
    "test:kotlin": "cd android && ./gradlew testDebugUnitTest --quiet",
    "test:native": "pnpm test:swift && pnpm test:kotlin",
    "test:all": "pnpm test:ts && pnpm test:native",
    "coverage": "jest --no-watchman --coverage",
    "coverage:ts": "jest --no-watchman --coverage",
    "coverage:swift": "cd packages/widget-utils && swift test --enable-code-coverage && xcrun llvm-cov report .build/debug/WidgetUtilsPackageTests.xctest/Contents/MacOS/WidgetUtilsPackageTests -instr-profile=.build/debug/codecov/default.profdata -ignore-filename-regex='.build|Tests'",
    "coverage:kotlin": "echo 'Note: Run pnpm test:kotlin for Kotlin tests. Full JaCoCo coverage requires additional setup.' && cd android && ./gradlew testDebugUnitTest 2>&1 | tail -5",
    "eas-build-pre-install": "./eas-build-pre-install.sh"
  },
  "dependencies": {
    "@bacons/apple-targets": "^3.0.6",
    "@dr.pogodin/react-native-fs": "^2.38.2",
    "@dr.pogodin/react-native-static-server": "^0.25.4",
    "@expo/metro-runtime": "^6.1.2",
    "@hocuspocus/provider": "^3.4.4",
    "@mlc-ai/web-llm": "^0.2.82",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@shopify/react-native-skia": "^2.2.12",
    "@tanstack/react-query": "^5.90.6",
    "@tauri-apps/api": "^2",
    "expo": "~54.0.33",
    "expo-application": "^7.0.7",
    "expo-audio": "^1.1.1",
    "expo-background-fetch": "~14.0.9",
    "expo-background-task": "~1.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "^8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-glass-effect": "~0.1.9",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "^8.0.11",
    "expo-localization": "^17.0.8",
    "expo-notifications": "^0.32.16",
    "expo-router": "^6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^6.0.9",
    "expo-task-manager": "^14.0.9",
    "expo-updates": "~29.0.16",
    "highlight.js": "^11.11.1",
    "isomorphic-webcrypto": "^2.3.8",
    "marked": "^17.0.0",
    "marked-highlight": "^2.2.3",
    "posthog-react-native": "^4.14.0",
    "quill": "1.3.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-argon2": "^3.0.0",
    "react-native-cn-quill": "^0.7.20",
    "react-native-executorch": "^0.6.0",
    "react-native-fast-confetti": "^1.1.1",
    "react-native-mmkv": "^4.1.1",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "^4.1.6",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-securerandom": "^1.0.1",
    "react-native-sherpa-onnx": "0.4.2",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "~0.5.1",
    "sql.js": "^1.14.1",
    "sql.js-fts5": "^1.4.0",
    "yjs": "^13.6.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@expo/webpack-config": "^19.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/minimatch": "^6.0.0",
    "@types/quill": "1",
    "@types/react": "~19.1.17",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-jest": "^29.7.0",
    "better-sqlite3": "^12.4.1",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.50.1"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --fix"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-securerandom",
          "react-native-argon2",
          "@bacons/apple-targets",
          "keyboard-module",
          "platform-ai",
          "widget-bridge"
        ]
      }
    }
  }
}
