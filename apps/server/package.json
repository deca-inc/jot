{
  "name": "@jot/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "jot-server": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts start",
    "start": "bun run src/cli.ts start",
    "jot-server": "bun run src/cli.ts",
    "create:migration": "bun run scripts/createMigration.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:run": "bun test",
    "coverage": "bun test --coverage",
    "build:exe": "bun build --compile src/cli.ts --outfile jot-server"
  },
  "dependencies": {
    "@hocuspocus/server": "^2.15.0",
    "argon2": "^0.44.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "ws": "^8.18.0",
    "yjs": "^13.6.21",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.2.4",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/ws": "^8.5.14",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.50.1"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix"
  }
}
