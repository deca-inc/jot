{
  "name": "@jot/server",
  "version": "1.0.10",
  "private": true,
  "type": "module",
  "bin": {
    "jot-server": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts start",
    "start": "bun run src/cli.ts start",
    "jot-server": "bun run src/cli.ts",
    "create:migration": "bun run scripts/createMigration.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:run": "bun test",
    "coverage": "bun test --coverage",
    "build": "bun build --compile src/cli.ts --outfile dist/jot-server",
    "build:all": "bun run scripts/build-all.ts",
    "build:current": "bun run scripts/build-all.ts --current",
    "build:archive": "bun run scripts/build-all.ts --archive",
    "build:macos-arm64": "bun build --compile src/cli.ts --outfile dist/jot-server-macos-arm64 --target=bun-darwin-arm64",
    "build:macos-x64": "bun build --compile src/cli.ts --outfile dist/jot-server-macos-x64 --target=bun-darwin-x64",
    "build:linux-x64": "bun build --compile src/cli.ts --outfile dist/jot-server-linux-x64 --target=bun-linux-x64",
    "build:linux-arm64": "bun build --compile src/cli.ts --outfile dist/jot-server-linux-arm64 --target=bun-linux-arm64",
    "build:windows": "bun build --compile src/cli.ts --outfile dist/jot-server-windows-x64 --target=bun-windows-x64",
    "release": "./scripts/release.sh",
    "release:dry": "./scripts/release.sh --dry"
  },
  "dependencies": {
    "@hocuspocus/server": "^3.4.4",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "ws": "^8.18.0",
    "yjs": "^13.6.21",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.2.4",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/ws": "^8.5.14",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.50.1"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix"
  }
}
